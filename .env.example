# Tale - AI Video Generation Pipeline
# Copy this file to .env and fill in your API keys

# =============================================================================
# OpenAI (GPT-4o) — optional, not used for image generation
# =============================================================================
OPENAI_API_KEY=sk-...

# =============================================================================
# Google Cloud / Vertex AI (Veo, Imagen)
# Multiple keys for rotation (comma-separated)
# Daily limit: ~10 videos per key
# =============================================================================
GOOGLE_API_KEYS=key1,key2,key3
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=us-central1

# =============================================================================
# Video Generation Settings
# =============================================================================
# Strategy: round_robin | least_used | random
VEO_KEY_ROTATION_STRATEGY=round_robin
# Max concurrent video generations per key
VEO_MAX_CONCURRENT_PER_KEY=2
# Daily limit per key (for tracking)
VEO_DAILY_LIMIT_PER_KEY=10

# =============================================================================
# Self-hosted Image Generation (Tailscale network)
# Optional — used when "Self-hosted" provider is selected in Artist page
# =============================================================================
TAILSCALE_IMAGE_API_URL=https://h100-image-gen.tailddf36d.ts.net
TAILSCALE_VIDEO_API_URL=https://pro6000-video-gen.tailddf36d.ts.net

# =============================================================================
# Output Settings
# =============================================================================
# =============================================================================
# Kling (direct API)
# =============================================================================
KLING_ACCESS_KEY=your-access-key
KLING_SECRET_KEY=your-secret-key

# =============================================================================
# fal.ai (Kling third-party — alternative video generation)
# =============================================================================
FAL_KEY=your-fal-key

# fal webhook 콜백을 받을 public base URL (이미지/영상 비동기 생성 완료 push).
#   - 프로덕션: 배포 도메인 (예: https://studio.tale.run). 미설정 시 Vercel은 VERCEL_URL 자동 사용.
#   - 로컬 개발: ngrok/cloudflare 터널 URL (예: https://xxxx.ngrok-free.app).
#   - 미설정 시 webhook 생략 → /api/generation-jobs polling이 fal을 직접 reconcile (느리지만 동작).
WEBHOOK_BASE_URL=

OUTPUT_DIR=./generated_videos
ASSETS_DIR=./assets

# =============================================================================
# Supabase (Video Reference DB)
# Create a new project at https://supabase.com/dashboard
# =============================================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
